{
  "name": "chessbot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Play chess against a style-trained bot",
  "scripts": {
    "build": "node scripts/build-book.mjs && vite build",
    "start": "node server/index.mjs",
    "dev": "node scripts/build-book.mjs && concurrently \"node --watch server/index.mjs\" \"vite\"",
    "build:book": "node scripts/build-book.mjs"
  },
  "dependencies": {
    "chess.js": "^1.0.0-beta.8",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-chessboard": "^4.7.2",
    "react-dom": "^18.3.1",
    "stockfish": "^18.0.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
